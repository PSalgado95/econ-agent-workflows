{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "econ-review data construction evidence manifest extension",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "source_lineage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "raw_inputs": {"type": ["array", "null"], "items": {"type": "string"}},
        "derived_inputs": {"type": ["array", "null"], "items": {"type": "string"}},
        "canonical_input": {"type": ["string", "null"]},
        "data_vintage": {"type": ["string", "null"]},
        "input_manifest_or_hash": {"type": ["string", "null"]}
      }
    },
    "unit_and_keys": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "unit_of_observation": {"type": ["string", "null"]},
        "primary_keys": {"type": ["array", "null"], "items": {"type": "string"}},
        "time_keys": {"type": ["array", "null"], "items": {"type": "string"}},
        "duplicate_diagnostics_path": {"type": ["string", "null"]},
        "key_repair_rules": {"type": ["string", "null"]}
      }
    },
    "joins_and_merges": {"type": "object", "additionalProperties": true},
    "filters_and_drops": {"type": "object", "additionalProperties": true},
    "missingness": {"type": "object", "additionalProperties": true},
    "support_and_overlap": {"type": "object", "additionalProperties": true},
    "denominators_and_weights": {"type": "object", "additionalProperties": true},
    "timing_alignment": {"type": "object", "additionalProperties": true},
    "intermediate_outputs": {"type": "object", "additionalProperties": true},
    "manual_steps": {"type": "object", "additionalProperties": true}
  }
}
