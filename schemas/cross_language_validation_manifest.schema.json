{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "econ-review cross-language validation manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["status", "primary_software", "comparison_software", "target_objects", "object_parity", "numeric_parity", "verdict"],
  "properties": {
    "status": {"enum": ["planned", "in_progress", "complete", "audited", "failed", "partial"]},
    "primary_software": {"type": "string"},
    "comparison_software": {"type": "string"},
    "validation_date": {"type": "string"},
    "independence_boundary": {"type": "string"},
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_data_or_input_version": {"type": "string"},
        "hash_or_manifest_id": {"type": "string"},
        "primary_code_path": {"type": "string"},
        "comparison_code_path": {"type": "string"}
      }
    },
    "target_objects": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "object_parity": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "numeric_parity": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "discrepancies": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "verdict": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "object_parity": {"enum": ["pass", "fail", "partial", "not_checked"]},
        "numeric_parity": {"enum": ["pass", "fail", "partial", "not_meaningful", "not_checked"]},
        "remaining_blockers": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
